{
  "name": "obsidian-mcp",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Obsidian vault MCP server intended to sit behind Cloudflare Access Managed OAuth.",
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "obsidian-headless": "0.0.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
