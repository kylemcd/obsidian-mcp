# HTTP
HOST=0.0.0.0
PORT=8787
VAULT_PATH=/vault
VAULT_NAME=Obsidian
READ_ONLY=true

# Obsidian Headless Sync
# Managed sync is enabled by default in the Docker image. Set this to false
# when another service already keeps VAULT_PATH synced.
SYNC_ENABLED=true
OBSIDIAN_REMOTE_VAULT=
OBSIDIAN_AUTH_TOKEN=
OBSIDIAN_SYNC_PASSWORD=
OBSIDIAN_DEVICE_NAME=obsidian-mcp

# Cloudflare Access
CF_ACCESS_REQUIRED=true
CF_ACCESS_TEAM_DOMAIN=https://<team>.cloudflareaccess.com
CF_ACCESS_AUD=<access-application-aud>
CF_ACCESS_ALLOWED_EMAILS=you@example.com

# Network hardening
ALLOWED_ORIGINS=https://claude.ai
ALLOWED_HOSTS=obsidian-mcp.example.com
RATE_LIMIT_PER_MINUTE=300
MCP_PUBLIC_URL=https://obsidian-mcp.example.com/mcp
