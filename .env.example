HOST=127.0.0.1
PORT=8787
MCP_PATH=/mcp
VAULT_PATH=/path/to/vault
VAULT_NAME=Obsidian
READ_ONLY=true

# Set these in production when the service is behind Cloudflare Access.
# With Managed OAuth, Cloudflare handles the OAuth flow before requests
# reach this origin. The origin only validates Cloudflare's assertion.
CF_ACCESS_REQUIRED=true
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CF_ACCESS_AUD=your-access-application-aud
CF_ACCESS_ALLOWED_EMAILS=you@example.com

# Optional browser origin guard. Non-browser MCP clients often omit Origin.
ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com,https://chat.openai.com
